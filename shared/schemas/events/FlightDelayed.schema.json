{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlightDelayed",
  "type": "object",
  "required": ["flightLegId", "flightNumber", "delayMinutes", "reasonCode"],
  "properties": {
    "flightLegId": { "type": "string" },
    "flightNumber": { "type": "string" },
    "delayMinutes": { "type": "integer", "minimum": 0 },
    "reasonCode": {
      "type": "string",
      "enum": ["WEATHER", "LATE_INBOUND", "CREW", "MAINTENANCE", "ATC", "BAGGAGE", "OTHER"]
    },
    "previousEta": { "type": "string", "format": "date-time" },
    "newEta": { "type": "string", "format": "date-time" }
  }
}
