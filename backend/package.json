    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.15.2",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.2",
    "typescript": "^5.4.0"
