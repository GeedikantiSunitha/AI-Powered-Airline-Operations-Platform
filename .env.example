# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# ─── Auth (Cognito or local JWT for dev) ───────────────────────
AUTH_PROVIDER=local
JWT_SECRET=change-me-in-production
ADMIN_MFA_REQUIRED=true
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1
# JWT claim for app role when using Cognito (default custom:role)
COGNITO_ROLE_CLAIM=custom:role

# ─── Database (local dev; production uses Redshift) ────────────
DATABASE_URL=postgresql://airline:airline@localhost:5432/airline_ops
REDIS_URL=redis://localhost:6379

# ─── AWS (fill when connecting cloud resources) ────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default
S3_DATA_LAKE_BUCKET=airline-data-lake-dev
REDSHIFT_WORKGROUP=
REDSHIFT_DATABASE=airline_ops
EVENTBRIDGE_BUS_NAME=airline-ops-events

# ─── ML / AI ───────────────────────────────────────────────────
SAGEMAKER_ENDPOINT_DELAY_PREDICTION=
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_AGENT_ID=

# ─── Observability ─────────────────────────────────────────────
LOG_LEVEL=info
ENABLE_XRAY=false
CLOUDWATCH_LOG_GROUP=/airline-ops/api
